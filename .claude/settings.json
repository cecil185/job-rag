{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pre-commit run --all-files && make test"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Read(/**)", "Read(~/Code/me/job-rag/**)", "Edit(/**)"],
    "deny": [
      "Edit(//**)",
      "Edit(~/**)",
      "Bash(git push)",
      "Bash(git commit)",
      "Bash(git rebase)",
      "Read(.env)",
      "Read(.env*)",
      "Read(**/.env)",
      "Read(**/.env*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyWrite": ["~/", "//"]
    }
  }
}
